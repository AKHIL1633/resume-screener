# Copy this file to .env and fill in your values

APP_NAME=ResumeIQ
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default for local development)
DATABASE_URL=sqlite+aiosqlite:///./resume_screener.db

# Oracle DB (uncomment and configure for production)
# DATABASE_URL=oracle+cx_oracle://username:password@hostname:1521/ORCL

# ── Auth / JWT ────────────────────────────────────────────────────────────────
# Generate a strong key with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── API limits ────────────────────────────────────────────────────────────────
MAX_PAGE_SIZE=100
